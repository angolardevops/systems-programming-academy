---
// PyRunner — run a self-contained Python snippet in the reader's browser.
//
// On the first "Run" click it lazy-loads Pyodide (CPython compiled to WebAssembly)
// from a CDN, then executes the code locally — nothing is sent to a server. Use it
// for the Academy's pure, stdlib-only examples so readers can edit and re-run them
// in place. Pass the code as the `code` prop (a JS string) rather than slot
// children, so MDX typography doesn't rewrite quotes or operators.
interface Props {
  code: string;
  label?: string;
}
const { code, label } = Astro.props;
---

<div class="py-runner not-content" data-py-runner>
  <div class="py-runner-bar">
    <span class="py-runner-label">{label ?? 'Python · runs in your browser'}</span>
    <button class="py-runner-run" type="button">▶ Run</button>
  </div>
  <textarea class="py-runner-code" spellcheck="false" aria-label="Editable Python code">{code}</textarea>
  <pre class="py-runner-out" hidden></pre>
</div>

<script>
  const PYODIDE_URL = 'https://cdn.jsdelivr.net/pyodide/v0.26.4/full/pyodide.js';
  let pyodidePromise: Promise<any> | undefined;

  function loadPyodideOnce(): Promise<any> {
    if (!pyodidePromise) {
      pyodidePromise = new Promise<void>((resolve, reject) => {
        const s = document.createElement('script');
        s.src = PYODIDE_URL;
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('Could not load the Python runtime.'));
        document.head.appendChild(s);
      }).then(() => (window as any).loadPyodide());
    }
    return pyodidePromise;
  }

  function wire(el: HTMLElement) {
    const btn = el.querySelector<HTMLButtonElement>('.py-runner-run')!;
    const code = el.querySelector<HTMLTextAreaElement>('.py-runner-code')!;
    const out = el.querySelector<HTMLPreElement>('.py-runner-out')!;

    // Auto-size the editor to its content.
    const resize = () => {
      code.style.height = 'auto';
      code.style.height = code.scrollHeight + 'px';
    };
    resize();
    code.addEventListener('input', resize);

    btn.addEventListener('click', async () => {
      out.hidden = false;
      out.textContent = 'Loading Python (the first run downloads the runtime)…';
      btn.disabled = true;
      try {
        const pyodide = await loadPyodideOnce();
        let buf = '';
        // Pyodide's `batched` stdout fires once per line WITHOUT the trailing
        // newline, so re-add it — otherwise multi-line output (e.g. a histogram)
        // collapses onto one line.
        const write = (s: string) => {
          buf += s + '\n';
          out.textContent = buf;
        };
        pyodide.setStdout({ batched: write });
        pyodide.setStderr({ batched: write });
        out.textContent = '';
        await pyodide.runPythonAsync(code.value);
        if (!buf) out.textContent = '(no output)';
      } catch (e) {
        out.textContent = String(e);
      } finally {
        btn.disabled = false;
      }
    });
  }

  document.querySelectorAll<HTMLElement>('[data-py-runner]').forEach(wire);
</script>

<style>
  .py-runner {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 1rem 0;
    background: var(--sl-color-bg-inline-code);
  }
  .py-runner-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.75rem;
    background: var(--sl-color-bg-sidebar);
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .py-runner-label {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono, monospace);
  }
  .py-runner-run {
    font-size: var(--sl-text-xs);
    font-weight: 600;
    color: var(--sl-color-white);
    background: var(--sl-color-accent);
    border: 0;
    border-radius: 0.375rem;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
  }
  .py-runner-run:hover { background: var(--sl-color-accent-high); }
  .py-runner-run:disabled { opacity: 0.6; cursor: progress; }
  .py-runner-code {
    display: block;
    width: 100%;
    box-sizing: border-box;
    border: 0;
    resize: vertical;
    padding: 0.75rem;
    font-family: var(--sl-font-mono, monospace);
    font-size: var(--sl-text-code);
    line-height: 1.5;
    color: var(--sl-color-text);
    background: transparent;
    overflow: hidden;
  }
  .py-runner-code:focus { outline: 2px solid var(--sl-color-accent); outline-offset: -2px; }
  .py-runner-out {
    margin: 0;
    padding: 0.75rem;
    border-top: 1px dashed var(--sl-color-hairline);
    background: var(--sl-color-black);
    color: var(--sl-color-gray-1);
    font-size: var(--sl-text-code);
    line-height: 1.5;
    /* Do NOT wrap: wide, aligned output (e.g. an ASCII histogram) must keep its
       columns and scroll sideways instead of breaking across lines. */
    white-space: pre;
    overflow-x: auto;
  }
</style>
